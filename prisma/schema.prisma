generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Auth (NextAuth compatible) ───────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  locale        String    @default("en")
  theme         String    @default("system")

  // Trial & subscription
  trialEndsAt DateTime?
  plan        String    @default("trial") // trial | pro | free

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts  Account[]
  sessions  Session[]
  exchanges Exchange[]
  setups    Setup[]
  trades    Trade[]
  chatSessions ChatSession[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Exchange connections ─────────────────────────────────────────────────────

model Exchange {
  id        String   @id @default(cuid())
  userId    String
  name      String   // e.g. "Binance", "Bybit", "OKX"
  apiKey    String
  apiSecret String
  passphrase String? // some exchanges require this
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades Trade[]
}

// ─── Trade setups ─────────────────────────────────────────────────────────────

model Setup {
  id          String  @id @default(cuid())
  userId      String
  name        String
  description String?
  rules       String? // JSON or markdown text for setup rules
  color       String? // hex color for UI display

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades Trade[]
}

// ─── Trades ───────────────────────────────────────────────────────────────────

model Trade {
  id         String @id @default(cuid())
  userId     String
  exchangeId String?
  setupId    String?

  // Core trade fields
  symbol      String   // e.g. "BTCUSDT"
  side        String   // "long" | "short"
  status      String   @default("open") // "open" | "closed" | "cancelled"
  entryPrice  Float
  exitPrice   Float?
  quantity    Float
  leverage    Float?   @default(1)
  stopLoss    Float?
  takeProfit  Float?
  pnl         Float?   // realized PnL
  pnlPercent  Float?   // PnL as percentage
  fees        Float?   @default(0)

  // Tracing / journaling fields
  setupReason     String? // reason for entering trade
  psychology      String? // emotional state / mindset
  marketCondition String? // trending, ranging, volatile, etc.
  confidenceLevel Int?    // 1-10 scale
  notes           String? // general notes

  entryDate DateTime  @default(now())
  exitDate  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  exchange Exchange? @relation(fields: [exchangeId], references: [id], onDelete: SetNull)
  setup    Setup?    @relation(fields: [setupId], references: [id], onDelete: SetNull)
  files    TradeFile[]
}

model TradeFile {
  id      String @id @default(cuid())
  tradeId String
  name    String
  url     String
  type    String // "image" | "document" | "screenshot"
  size    Int?

  createdAt DateTime @default(now())

  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
}

// ─── AI Chat ──────────────────────────────────────────────────────────────────

model ChatSession {
  id     String @id @default(cuid())
  userId String
  title  String @default("New Chat")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]
}

model ChatMessage {
  id            String @id @default(cuid())
  chatSessionId String
  role          String // "user" | "assistant" | "system"
  content       String

  createdAt DateTime @default(now())

  chatSession ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
}

// ─── Partners ─────────────────────────────────────────────────────────────────

model Partner {
  id                    String @id @default(cuid())
  code                  String @unique
  email                 String
  name                  String?
  discountPercent       Float  @default(0)
  shareCommissionPercent Float @default(0)
  isActive              Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
